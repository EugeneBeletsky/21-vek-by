{
  "name": "21-vek",
  "version": "1.0.0",
  "description": "This project will cover e2e tests for https://www.21vek.by/",
  "main": "index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EugeneBeletsky/21-vek-by.git"
  },
  "keywords": [],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "playwright test",
    "test:ui": "playwright test --grep-invert @api --project=chromium",
    "test:ui:auth": "playwright test --project=chromium-auth",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test --grep @api",
    "test:chrome": "playwright test --project=chromium",
    "test:parallel": "playwright test --workers=4",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:allure:generate": "allure generate allure-results --clean -o allure-report",
    "report:allure:open": "allure open allure-report",
    "report:allure:clean": "npx rimraf allure-results allure-report"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/EugeneBeletsky/21-vek-by/issues"
  },
  "homepage": "https://github.com/EugeneBeletsky/21-vek-by#readme",
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "@eslint/js": "^10.0.1",
    "eslint-plugin-playwright": "^2.10.2",
    "typescript-eslint": "^8.58.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "eslint-config-prettier": "^10.1.8",
    "@typescript-eslint/parser": "^8.59.2",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.2",
    "npm": "^11.13.0",
    "prettier": "^3.8.3",
    "@faker-js/faker": "^10.4.0"
  }
}
