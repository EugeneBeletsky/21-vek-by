{
  "name": "21-vek",
  "version": "1.0.0",
  "description": "This project will cover e2e tests for https://www.21vek.by/",
  "main": "index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EugeneBeletsky/21-vek-by.git"
  },
  "keywords": [],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "playwright test",
    "test:ui": "playwright test --grep-invert @api --project=chromium",
    "test:ui:auth": "playwright test --project=chromium-auth",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test --grep @api",
    "test:chrome": "playwright test --project=chromium",
    "test:parallel": "playwright test --workers=4",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/EugeneBeletsky/21-vek-by/issues"
  },
  "homepage": "https://github.com/EugeneBeletsky/21-vek-by#readme",
  "dependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.21",
    "dayjs": "^1.11.13",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "eslint-plugin-playwright": "^2.2.0",
    "npm": "^11.4.1",
    "prettier": "^3.5.3"
  }
}
